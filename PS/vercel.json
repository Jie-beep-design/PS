{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-community/php@0.4.0"
    },
    "*.php": {
      "runtime": "vercel-community/php@0.4.0"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.php)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
